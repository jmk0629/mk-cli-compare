# 환경변수 템플릿 — 복사해서 `.env` 로 만들고 실제 값으로 채우세요.
#   cp .env.sample .env
# 실제 키가 담긴 .env 는 커밋되지 않습니다 (.gitignore).
# backend 의 `./gradlew bootRun` 이 루트 `.env` 를 자동 로드 (build.gradle.kts 참조).

# 백엔드 (Spring Boot)
SPRING_PROFILES_ACTIVE=local
SERVER_PORT=8080

# 프론트엔드 (Next.js)
NEXT_PUBLIC_API_BASE=http://localhost:8080

# CORS (쉼표로 다중 허용)
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ─────────────────────────────────────────────────────────────────────────────
# 회원/SNS 로그인. 크로스오리진 → JWT in-header.
# JWT 서명 비밀 — HS256, 최소 32바이트. 운영은 강한 랜덤값 필수.  생성: openssl rand -base64 48
JWT_SECRET=replace-with-random-min-32-bytes
JWT_EXPIRY_MINUTES=10080
# OAuth 성공 후 토큰을 실어 redirect 할 프론트 URL
APP_WEB_URL=http://localhost:3000

# OAuth provider — 각 콘솔에서 발급 + redirect URI 등록:
#   redirect URI = {API_BASE}/login/oauth2/code/{google|kakao|naver}
# 미설정 provider 는 자동 비활성(해당 로그인만 동작 안 함). 앱은 비로그인으로 완전 동작.
# Google — https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Kakao  — https://developers.kakao.com (REST API 키 = client-id)
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
# Naver  — https://developers.naver.com/apps
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# ─────────────────────────────────────────────────────────────────────────────
# CLI 비교 엔진 — 구독형 CLI 를 서브프로세스로 실행해 같은 프롬프트를 비교.
# 각 provider 는 로컬에 설치된 CLI 바이너리를 비대화형(headless) 모드로 호출.
# 미설치/비활성 provider 는 자동으로 건너뜀(카탈로그 enabled=0 또는 binary 미존재).
#
# 실행 타임아웃(초). 응답이 길거나 모델이 느릴 수 있으니 넉넉히.
CLI_TIMEOUT_SECONDS=120
# 동시 실행 허용 여부(true=세 CLI 병렬, false=순차). 병렬이 빠르지만 자원 사용 큼.
CLI_PARALLEL=true
# 각 CLI 바이너리 경로(미지정 시 PATH 에서 탐색). 설치 위치가 다르면 절대경로 지정.
#   claude  : Claude Code CLI      (claude -p "<prompt>")
#   agy     : Antigravity CLI(Gemini) (agy -p "<prompt>")
#   codex   : OpenAI Codex CLI      (codex exec "<prompt>")
CLI_CLAUDE_BIN=claude
CLI_AGY_BIN=agy
CLI_CODEX_BIN=codex

# ─────────────────────────────────────────────────────────────────────────────
# (선택) API 직접 호출 fallback — CLI 미설치 환경에서 Gemini 만 API 로 대체 가능.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite
